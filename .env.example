# Variáveis de ambiente para configuração de email
# Copie este arquivo para .env e preencha com suas credenciais

# Configuração de Email (Gmail)
EMAIL_ADDRESS=seu_email@gmail.com
EMAIL_PASSWORD=sua_senha_de_app

# Servidor SMTP (padrão: Gmail)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587

# Para usar Gmail, gere uma Senha de App em: https://myaccount.google.com/apppasswords
