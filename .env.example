# Variaveis de ambiente para configuracao de email
# Copie este arquivo para .env e preencha com suas credenciais

# Configuracao de Email (Resend SMTP)
EMAIL_FROM=contato@seudominio.com.br
SMTP_USERNAME=resend
SMTP_PASSWORD=sua_api_key_resend

# Servidor SMTP (padrao: Resend)
SMTP_SERVER=smtp.resend.com
SMTP_PORT=465
PORT=5000

# Configuracoes da aplicacao
ADMIN_PASSWORD=troque-esta-senha-admin
SECRET_KEY=troque-esta-chave-secreta-por-uma-string-longa-e-unica
